# =====================================================================
#  Configuration SMTP — Week-end Artisanal Famiflora
#  Copiez ce fichier en « .env » et renseignez vos identifiants.
#  (Sur Railway : ajoutez ces variables dans l'onglet « Variables ».)
# =====================================================================

# Serveur SMTP de votre fournisseur (ex. Office365, Gmail, OVH, Mailgun…)
SMTP_HOST=smtp.exemple.be
SMTP_PORT=587
# true UNIQUEMENT pour le port 465 (SSL). Pour 587 (STARTTLS), laissez false.
SMTP_SECURE=false

# Identifiants du compte d'envoi
SMTP_USER=no-reply@famiflora.be
SMTP_PASS=votre_mot_de_passe_ou_cle_app

# Expéditeur affiché dans les e-mails
MAIL_FROM=Week-end Artisanal Famiflora <no-reply@famiflora.be>

# Destinataire des notifications (organisateur qui reçoit les pré-inscriptions)
MAIL_TO=cyril.loiseau@famiflora.be

# Copie cachée éventuelle (facultatif)
# MAIL_BCC=archive@famiflora.be
